{
  "name": "heriel",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --bun run --filter @heriel/app --filter @heriel/api dev",
    "dev:web": "bun --bun run --filter @heriel/web dev",
    "build:app": "bun --bun --elide-lines=0 run --filter @heriel/app build",
    "start": "bun --bun run --filter  @heriel/api start",
    "check": "biome check .",
    "fix": "biome check --fix ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  }
}
